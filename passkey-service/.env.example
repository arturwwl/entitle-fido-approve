# -----------------------------------------------------------------------
# passkey-gate service — environment variables
# Copy this file to .env and fill in the values before running.
# -----------------------------------------------------------------------

# Port the Express server listens on
PORT=3000

# Session secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me

# -----------------------------------------------------------------------
# WebAuthn / Passkey
# -----------------------------------------------------------------------

# Human-readable name shown in the passkey prompt
RP_NAME=Entitle Passkey Gate

# Must be the domain (no scheme, no port) where this service is hosted.
# For local dev with ngrok: the ngrok subdomain, e.g. abc123.ngrok-free.app
RP_ID=localhost

# Full origin including scheme.  Must match what the browser sees.
# For local dev with ngrok: https://abc123.ngrok-free.app
ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------

# Personal Access Token (or GitHub App installation token) with:
#   repo:status  — to post commit statuses
#   pull_requests:write — to dismiss reviews and post comments
GITHUB_APP_TOKEN=ghp_...

# Webhook secret — set the same value in your GitHub repo/app webhook config
GITHUB_WEBHOOK_SECRET=change-me

# Number of passkey-verified approvals required before the gate passes
REQUIRED_APPROVALS=2
